# Supabase Configuration
# Copy this file to .env.local and fill in your Supabase credentials
# Get them from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role (server-only — JANGAN pakai NEXT_PUBLIC prefix)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=powerops-photos
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Google Sheets — spreadsheet "Catatan Operasional" (kolom B tanggal / C shift / D catatan).
# Opsional: ada fallback hardcoded di lib/google-sheets.ts.
GOOGLE_SHEETS_CATATAN_ID=1qbN1nrpJmVJ_WY2YPGB4TCJixLrf5cwAyycqqHZC1mw
# LogSheet Boiler — spreadsheet terpisah utk station Bunker & Lapangan Boiler.
# Opsional: ada fallback hardcoded di lib/logsheet-boiler.ts.
GOOGLE_SHEETS_LOGSHEET_BOILER_ID=1WYvAIag7BcjHafR9bWcZOQtRklAi-hU6j_ouDTaFskE

# Fonnte WhatsApp API
# FONNTE_TOKEN         → akun NOTIF: reminder isi laporan shift/harian (grup A–D), photo-bot.
# FONNTE_TOKEN_PUBLISH → akun PUBLISH: publish laporan ke washift, Utilitas 2, SU 3A.
FONNTE_TOKEN=your-fonnte-device-token
FONNTE_TOKEN_PUBLISH=your-fonnte-publish-device-token
# Account token Fonnte (referensi saja — belum dipakai kode).
FONNTE_ACCOUNT_TOKEN=your-fonnte-account-token

# WhatsApp Notifications — Cron security & deep links
# CRON_SECRET: random string (32+ chars). Set as Bearer token in cron-job.org.
# NEXT_PUBLIC_APP_URL: public app URL used for deep-link in reminder messages.
CRON_SECRET=replace-with-strong-random-string
NEXT_PUBLIC_APP_URL=https://your-app.example.com
