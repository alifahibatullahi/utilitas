# ── Konfigurasi container WAHA (dipakai docker-compose.yml di folder ini) ──
# Copy file ini menjadi ".env" di folder waha/, lalu isi nilainya.
# JANGAN commit file .env (sudah di-ignore).

# API key untuk container NOTIF (:3000). Pakai string acak panjang.
WAHA_API_KEY=ganti_string_acak_panjang_notif

# API key untuk container PUBLISH (:3001). Boleh beda dari notif.
WAHA_API_KEY_PUBLISH=ganti_string_acak_panjang_publish

# Login dashboard monitoring (http://IP:3000/dashboard & :3001/dashboard).
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=ganti_password_dashboard

# ── Env berikut TIDAK dipakai container ini, tapi WAJIB diset di APLIKASI ──
# ── PowerOps (Vercel → Environment Variables). Ditaruh di sini sbg catatan. ──
#
# WAHA_BASE_URL=https://waha-notif.domainmu.com      # atau http://IP-VPS:3000
# WAHA_API_KEY=<sama dgn WAHA_API_KEY di atas>
# WAHA_SESSION=default
#
# WAHA_BASE_URL_PUBLISH=https://waha-publish.domainmu.com   # atau http://IP-VPS:3001
# WAHA_API_KEY_PUBLISH=<sama dgn WAHA_API_KEY_PUBLISH di atas>
# WAHA_SESSION_PUBLISH=default
