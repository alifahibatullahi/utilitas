---
title: Workflow Laporan Shift & Harian — Sebelum vs Sesudah PowerOps
---
flowchart TB

%% ============== SEBELUM (kolom kiri) ==============
subgraph BEFORE["🔴 SEBELUM PowerOps"]
    direction TB
    OP_B["Operator 1, 2, … N"]
    HT(["Komunikasi via HT<br/>(satu per satu)"])
    CCRB["CCR catat di Logbook"]
    FOREB["Foreman tulis ulang<br/>ke Spreadsheet<br/>⚠️ double input"]
    SUPB["Supervisor<br/>review laporan"]
    TEL(["Telepon ke Washift<br/>(manual)"])
    WAB["Washift"]

    OP_B --> HT --> CCRB --> FOREB --> SUPB --> TEL --> WAB
end

%% ============== TAHAPAN (kolom tengah) ==============
subgraph STAGES["📋 Tahapan"]
    direction TB
    T1["1. Input Operator"]
    T2["2. Channel Komunikasi"]
    T3["3. Pencatatan"]
    T4["4. Konsolidasi Data"]
    T5["5. Review &amp; Approval"]
    T6["6. Distribusi"]
    T7["7. Penerima Laporan"]

    T1 ~~~ T2 ~~~ T3 ~~~ T4 ~~~ T5 ~~~ T6 ~~~ T7
end

%% ============== SESUDAH (kolom kanan) ==============
subgraph AFTER["🟢 SESUDAH PowerOps"]
    direction TB
    OP_A["Operator 1, 2, … N"]
    PO[/"Input langsung ke<br/>Form PowerOps"/]
    DB[("Database PowerOps<br/>(single source of truth)")]
    SKIP["✨ Otomatis<br/>(tidak perlu input ulang)"]
    REVIEW{"Foreman / Supervisor<br/>ACC laporan"}
    AUTO(["Auto-distribute"])
    RECV["Washift &nbsp;+&nbsp; WhatsApp Group"]

    OP_A --> PO --> DB --> SKIP --> REVIEW --> AUTO --> RECV
end

%% ============== ALIGN per tahap (invisible links) ==============
OP_A ~~~ T1 ~~~ OP_B
PO   ~~~ T2 ~~~ HT
DB   ~~~ T3 ~~~ CCRB
SKIP ~~~ T4 ~~~ FOREB
REVIEW ~~~ T5 ~~~ SUPB
AUTO ~~~ T6 ~~~ TEL
RECV ~~~ T7 ~~~ WAB

