%% ============== SEBELUM ==============
subgraph BEFORE["🔴 SEBELUM PowerOps"]
    direction TB
    OP1B["Operator 1"]
    OP2B["Operator 2"]
    OPNB["Operator N"]
    HT(["Komunikasi via HT<br/>(satu per satu)"])
    CCRB["CCR<br/>catat di Logbook"]
    LOG[("Logbook<br/>(tulis tangan)")]
    FOREB["Foreman<br/>tulis ke Spreadsheet"]
    SS[("Spreadsheet")]
    SUPB["Supervisor"]
    TEL(["Telepon ke Washift"])
    WAB["Washift"]
    WAG1["WhatsApp Group<br/>(share manual)"]

    OP1B --> HT
    OP2B --> HT
    OPNB --> HT
    HT --> CCRB
    CCRB --> LOG
    CCRB -.->|"laporan diteruskan"| FOREB
    LOG -.->|"double input"| FOREB
    FOREB --> SS
    SS --> SUPB
    SUPB --> TEL --> WAB
    SUPB -->|"copy paste manual"| WAG1
end

%% ============== SESUDAH ==============
subgraph AFTER["🟢 SESUDAH PowerOps"]
    direction TB
    OP1A["Operator 1"]
    OP2A["Operator 2"]
    OPNA["Operator N"]
    PO[/"PowerOps<br/>Form Laporan"/]
    DB[("Database PowerOps<br/>(single source of truth)")]
    REVIEW{"Foreman / Supervisor<br/>Review laporan"}
    REVISI["Revisi oleh Operator"]
    AUTO(["Auto-distribute"])
    WAGA["WhatsApp Group"]
    WAA["Washift"]

    OP1A --> PO
    OP2A --> PO
    OPNA --> PO
    PO --> DB
    DB --> REVIEW
    REVIEW -- "Tolak" --> REVISI --> PO
    REVIEW -- "ACC" --> AUTO
    AUTO --> WAGA
    AUTO --> WAA
end

